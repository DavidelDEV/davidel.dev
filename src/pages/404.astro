---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Pagină negăsită">
  <section class="not-found">
    <div class="container">
      <p class="error-code">404</p>
      <h1>Pagina <span class="accent">nu există</span></h1>
      <p class="error-sub">Fie ai greșit adresa, fie pagina a dispărut în neant digital.</p>
      <a href="/" class="btn btn-primary">← Înapoi acasă</a>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    text-align: center;
  }

  .error-code {
    font-family: var(--font-mono);
    font-size: 8rem;
    font-weight: 700;
    color: var(--accent);
    opacity: 0.15;
    line-height: 1;
    margin-bottom: -1rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
  }

  .accent { color: var(--accent-bright); }

  .error-sub {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 1rem;
  }
</style>
