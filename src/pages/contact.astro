---
import Layout from '../layouts/Layout.astro';

const socials = [
  {
    name: "Email",
    value: "david@davidel.dev",
    href: "mailto:david@davidel.dev",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`
  },
  {
    name: "GitHub",
    value: "github.com/DavidelDEV",
    href: "https://github.com/DavidelDEV",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>`
  },
  {
    name: "Discord",
    value: "davideldev",
    href: "https://discord.com/users/davideldev",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.08.114 18.1.136 18.116a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>`
  },
];
---

<Layout title="Contact" description="Contactează-l pe davidel.dev — hai să vorbim despre proiectul tău.">

  <section class="section contact-hero">
    <div class="container">
      <p class="tag fade-in">Contact</p>
      <h1 class="page-title fade-in">Hai să <span class="accent">vorbim</span></h1>
      <p class="page-sub fade-in">
        Fie că ai un proiect interesant, o colaborare sau pur și simplu vrei să dai un salut — 
        sunt mereu deschis la conversații. Răspund de obicei în 24h.
      </p>
      <div class="divider fade-in"></div>
    </div>
  </section>

  <section class="section contact-main">
    <div class="container">
      <div class="socials-list">
        {socials.map(social => (
          <a href={social.href} target={social.href.startsWith('mailto') ? '_self' : '_blank'} rel="noopener" class="social-card fade-in">
            <div class="social-icon" set:html={social.icon}></div>
            <div class="social-info">
              <span class="social-name">{social.name}</span>
              <span class="social-value">{social.value}</span>
            </div>
            <svg class="social-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-hero {
    padding-top: 10rem;
    padding-bottom: 2rem;
  }

  .contact-hero .tag {
    display: block;
    margin-bottom: 1rem;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 1rem;
  }

  .accent { color: var(--accent-bright); }

  .page-sub {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .socials-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 520px;
  }

  .social-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all var(--transition);
  }

  .social-card:hover {
    border-color: var(--border-hover);
    background: var(--bg-card-hover);
    transform: translateX(4px);
  }

  .social-icon {
    color: var(--accent-bright);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-glow);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .social-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .social-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .social-value {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .social-arrow {
    color: var(--text-muted);
    transition: all var(--transition);
    flex-shrink: 0;
  }

  .social-card:hover .social-arrow {
    color: var(--accent-bright);
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .contact-hero {
      padding-top: 7rem;
      padding-bottom: 1rem;
    }

    .page-sub {
      font-size: 0.95rem;
    }

    .socials-list {
      max-width: 100%;
    }

    .social-card {
      padding: 1rem;
      gap: 0.85rem;
      align-items: flex-start;
    }

    .social-value {
      word-break: break-word;
    }
  }

  @media (max-width: 480px) {
    .social-card {
      display: grid;
      grid-template-columns: 40px 1fr auto;
      gap: 0.75rem;
    }

    .social-arrow {
      align-self: center;
    }
  }
</style>
